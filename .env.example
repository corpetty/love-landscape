# ─── Supabase (frontend build — expose via Vite) ─────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ─── Supabase (backend API functions only — NOT exposed to browser) ───────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── Anthropic (backend API functions only) ───────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# Model overrides (optional — defaults shown)
# MANAGED_MODEL_FAST=claude-haiku-4-5        # param adjustment (fast/cheap)
# MANAGED_MODEL_QUALITY=claude-sonnet-4-5    # narrative + pair readings

# Free credits per new anonymous session (optional, default: 5)
# FREE_CREDITS=5

# ─── Stripe (backend API functions only) ─────────────────────────────────────
# 1. Create a product + price at https://dashboard.stripe.com/products
# 2. Add https://love-landscape.com/api/webhook as a webhook endpoint
#    for the event: checkout.session.completed
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...
STRIPE_CREDITS_PER_PACK=20

# ─── App public URL (for Stripe redirect after payment) ───────────────────────
VITE_PUBLIC_URL=https://love-landscape.com
